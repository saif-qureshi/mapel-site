---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Whatsapp from '../components/Whatsapp.astro';

const {
  title,
  description,
  active,
  ogTitle,
  ogDescription,
  ogImage,
  jsonLd,
  whatsappMessage,
  noindex,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage ?? '/og-image.png', Astro.site).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Maple Leaf Corporation',
  alternateName: 'Maple Leaf ERP',
  url: 'https://mapleleafcorporation.com',
  logo: 'https://mapleleafcorporation.com/assets/logo.png',
  image: 'https://mapleleafcorporation.com/og-image.png',
  description:
    'FBR-compliant ERP and digital invoicing software for Pakistani businesses.',
  telephone: '+92-332-0003527',
  email: 'raabta@mapleleafcorporation.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Suit # F-52, First Floor, Mateen Plaza, Main Tariq Road',
    addressLocality: 'Karachi',
    addressCountry: 'PK',
  },
  sameAs: [
    'https://www.facebook.com/profile.php?id=61582122462586',
    'https://www.instagram.com/mapleleafcorp1',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8ZRDHBC338" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-8ZRDHBC338');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#dc2626" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
    <meta property="og:site_name" content="Maple Leaf ERP" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Maple Leaf ERP — FBR Digital Invoicing" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body class="antialiased bg-white font-sans">
    <Header active={active} />
    <slot />
    <Footer />
    <Whatsapp message={whatsappMessage} />

    <script>
      // Mobile menu toggle + smooth scroll for in-page anchors (shared across all pages)
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      document.querySelectorAll('a[href*="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const a = anchor as HTMLAnchorElement;
          const url = new URL(a.href, location.href);
          if (url.pathname === location.pathname && url.hash) {
            const target = document.querySelector(url.hash);
            if (target) {
              e.preventDefault();
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
              menu?.classList.add('hidden');
            }
          }
        });
      });
    </script>
  </body>
</html>
