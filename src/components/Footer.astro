---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 py-8 md:py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-6 md:mb-8">
      <div class="col-span-2 md:col-span-1">
        <img
          src="/assets/logo.png"
          alt="Maple Leaf Corporation"
          class="h-10 md:h-12 mb-3 md:mb-4 brightness-0 invert"
        />
        <p class="text-xs md:text-sm text-gray-400">
          Complete ERP solution for modern businesses.
        </p>
      </div>

      <div>
        <h3 class="text-white text-sm md:text-base font-semibold mb-3 md:mb-4">Product</h3>
        <ul class="space-y-2 text-xs md:text-sm">
          <li><a href="/#features" class="hover:text-white transition">Features</a></li>
          <li><a href="/pricing/" class="hover:text-white transition">Pricing</a></li>
          <li><a href="/pricing/#faqs" class="hover:text-white transition">FAQs</a></li>
          <li><a href="/fbr-integration/" class="hover:text-white transition">FBR Digital Invoicing</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white text-sm md:text-base font-semibold mb-3 md:mb-4">Company</h3>
        <ul class="space-y-2 text-xs md:text-sm">
          <li><a href="/about/" class="hover:text-white transition">About</a></li>
          <li><a href="#" class="hover:text-white transition">Blog</a></li>
          <li><a href="/privacy/" class="hover:text-white transition">Privacy Policy</a></li>
          <li><a href="/terms/" class="hover:text-white transition">Terms &amp; Conditions</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white text-sm md:text-base font-semibold mb-3 md:mb-4">Support</h3>
        <ul class="space-y-2 text-xs md:text-sm">
          <li><a href="/contact/" class="hover:text-white transition">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-6 md:pt-8">
      <p class="text-xs md:text-sm text-gray-400 text-center">
        © {year} Maple Leaf Corporation. All rights reserved.
      </p>
    </div>
  </div>
</footer>
