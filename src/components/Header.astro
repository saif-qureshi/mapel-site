---
const { active } = Astro.props;

const items = [
  { href: '/#features', label: 'Features', key: 'features' },
  { href: '/fbr-integration', label: 'FBR Invoicing', key: 'fbr' },
  { href: '/pricing', label: 'Pricing', key: 'pricing' },
  { href: '/contact', label: 'Contact', key: 'contact' },
  { href: '/pricing#faqs', label: 'FAQs', key: 'faqs' },
];

const cls = (key) =>
  key === active
    ? 'text-gray-900 text-sm font-medium transition'
    : 'text-gray-600 hover:text-gray-900 text-sm font-medium transition';

const mcls = (key) =>
  key === active
    ? 'block text-gray-900 text-sm font-medium'
    : 'block text-gray-600 hover:text-gray-900 text-sm font-medium';
---

<nav class="fixed w-full z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/">
          <img src="/assets/logo.png" alt="Maple Leaf Corporation" class="h-[6.5rem]" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {items.map((i) => <a href={i.href} class={cls(i.key)}>{i.label}</a>)}
      </div>

      <!-- Right Side -->
      <div class="hidden md:flex items-center space-x-4">
        <a
          href="https://app.mapleleafcorporation.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 hover:text-primary-700 font-medium text-sm transition"
          >Login</a
        >
        <a
          href="/contact"
          class="bg-primary-600 text-white px-5 py-2 rounded-lg font-medium text-sm hover:bg-primary-700 transition"
        >
          Get started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden text-gray-700" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
    <div class="px-4 py-4 space-y-3">
      {items.map((i) => <a href={i.href} class={mcls(i.key)}>{i.label}</a>)}
      <a
        href="https://app.mapleleafcorporation.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="block text-primary-600 hover:text-primary-700 font-medium text-sm"
        >Login</a
      >
      <a
        href="/contact"
        class="w-full bg-primary-600 text-white px-5 py-2 rounded-lg font-medium text-sm hover:bg-primary-700 transition block text-center"
      >
        Get started
      </a>
    </div>
  </div>
</nav>
