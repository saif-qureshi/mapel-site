---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const title = "Blog | Maple Leaf Corporation";
const description =
  "Insights on FBR digital invoicing, ERP software, and tax compliance for Pakistani businesses.";
---

<Layout title={title} description={description} active="blog">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 via-red-50 to-orange-50 pt-28 pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-3 md:mb-4">Blog</h1>
      <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto">
        Insights on FBR digital invoicing, ERP software, and tax compliance for Pakistani businesses.
      </p>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-5 md:gap-6">
      {
        posts.map((p) => (
          <a
            href={`/blog/${p.slug}/`}
            class="block bg-white border border-gray-200 rounded-2xl p-6 md:p-8 hover-lift"
          >
            <time class="text-xs md:text-sm text-primary-600 font-semibold">{fmt(p.data.pubDate)}</time>
            <h2 class="text-lg md:text-2xl font-bold text-gray-900 mt-2 mb-2 leading-snug">{p.data.title}</h2>
            <p class="text-sm md:text-base text-gray-600 leading-relaxed">{p.data.description}</p>
            <span class="inline-flex items-center gap-1 text-primary-600 font-medium text-sm mt-4">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
