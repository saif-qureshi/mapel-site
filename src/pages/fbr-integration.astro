---
import Layout from '../layouts/Layout.astro';

const title = "FBR Digital Invoicing Integration | Maple Leaf ERP Pakistan";
const description =
  "Get FBR-compliant with Maple Leaf ERP. We connect your invoicing directly to FBR's Digital Invoicing system — real-time submission, automatic IRN and QR codes, sandbox testing before go-live.";
const ogTitle = "FBR Digital Invoicing Integration | Maple Leaf ERP";
const ogDescription =
  "Maple Leaf ERP submits your invoices to FBR in real time and prints the IRN and QR code on every invoice. Built for Pakistani businesses.";
const whatsappMessage =
  "Hello! I need help with FBR digital invoicing integration for my business.";
---

<Layout title={title} description={description} active="fbr" ogTitle={ogTitle} ogDescription={ogDescription} whatsappMessage={whatsappMessage}>
    <!-- Hero Section -->
    <section
      class="bg-gradient-to-br from-primary-50 via-red-50 to-orange-50 pt-28 pb-16"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1
          class="text-3xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-4 md:mb-6"
        >
          FBR Digital Invoicing, handled for you
        </h1>
        <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
          FBR now requires sales-tax-registered businesses to submit invoices
          electronically in real time. Maple Leaf ERP does this automatically —
          every invoice goes to FBR, comes back with an IRN and QR code, and
          prints ready to issue.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
          <a
            href="/contact/?message=I'd%20like%20to%20book%20an%20FBR%20digital%20invoicing%20demo%20for%20my%20business."
            class="bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-primary-700 transition"
          >
            Book an FBR demo
          </a>
          <a
            href="/pricing/"
            class="border-2 border-primary-600 text-primary-600 px-8 py-3 rounded-lg font-semibold text-base hover:bg-primary-50 transition"
          >
            See plans
          </a>
        </div>
      </div>
    </section>

    <!-- What it is -->
    <section class="py-14 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">
          What is FBR Digital Invoicing?
        </h2>
        <p class="text-sm md:text-lg text-gray-600 leading-relaxed mb-4">
          Under FBR's digital invoicing framework, sales-tax-registered
          businesses must send each sales invoice to FBR's system as it is
          issued. FBR validates the invoice and returns a unique Invoice
          Reference Number (IRN) along with a QR code that must appear on the
          printed invoice.
        </p>
        <p class="text-sm md:text-lg text-gray-600 leading-relaxed">
          Done manually, this means uploading data invoice by invoice and
          reconciling errors by hand. Maple Leaf ERP removes that work entirely —
          the connection to FBR is built into the invoice you already create.
        </p>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-14 md:py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10 md:mb-14">
          <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-3">
            How it works inside Maple Leaf ERP
          </h2>
          <p class="text-sm md:text-lg text-gray-600 max-w-2xl mx-auto">
            From creating an invoice to a compliant, FBR-validated document — in
            seconds, with no manual uploads.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-5 md:gap-8">
          <div class="bg-white p-6 md:p-8 rounded-2xl border border-gray-100 hover-lift">
            <div class="w-11 h-11 bg-primary-100 text-primary-700 rounded-lg flex items-center justify-center font-bold text-lg mb-4">1</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Create the invoice</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              Build your sales invoice as usual — items, quantities, tax rates and
              buyer details. The system prepares it in the exact format FBR
              requires.
            </p>
          </div>
          <div class="bg-white p-6 md:p-8 rounded-2xl border border-gray-100 hover-lift">
            <div class="w-11 h-11 bg-primary-100 text-primary-700 rounded-lg flex items-center justify-center font-bold text-lg mb-4">2</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Submit to FBR</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              On submit, the invoice is sent to FBR's Digital Invoicing system in
              real time. FBR validates it and returns the IRN — or a clear error
              message if something needs fixing.
            </p>
          </div>
          <div class="bg-white p-6 md:p-8 rounded-2xl border border-gray-100 hover-lift">
            <div class="w-11 h-11 bg-primary-100 text-primary-700 rounded-lg flex items-center justify-center font-bold text-lg mb-4">3</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Print &amp; issue</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              The FBR IRN and QR code are placed on the invoice automatically. You
              print or share a fully compliant document — every record kept and
              audit-ready.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- What's covered -->
    <section class="py-14 md:py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-start">
          <div>
            <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">
              Built for real Pakistani tax scenarios
            </h2>
            <p class="text-sm md:text-lg text-gray-600 leading-relaxed">
              Different goods carry different sales-tax treatment, and FBR
              validates each one. Maple Leaf ERP handles the full range out of the
              box, with the right SRO and item references applied automatically.
            </p>
          </div>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm md:text-base text-gray-700">Standard-rate, reduced-rate, zero-rated and exempt supplies</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm md:text-base text-gray-700">3rd Schedule goods, further tax and extra tax</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm md:text-base text-gray-700">Registered and unregistered buyers</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm md:text-base text-gray-700">Sandbox testing before go-live, so you submit with confidence</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm md:text-base text-gray-700">Live IRN and QR code on every validated invoice</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-4">
          Get FBR-compliant with Maple Leaf ERP
        </h2>
        <p class="text-sm md:text-lg text-gray-600 mb-8">
          Book a walkthrough and we'll show you exactly how digital invoicing
          works for your business — from setup and testing to your first live
          invoice.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact/?message=I'd%20like%20to%20book%20an%20FBR%20digital%20invoicing%20demo%20for%20my%20business."
            class="bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-primary-700 transition"
          >
            Book your integration demo
          </a>
          <a
            href="/pricing/"
            class="border-2 border-primary-600 text-primary-600 px-8 py-3 rounded-lg font-semibold text-base hover:bg-primary-50 transition"
          >
            View pricing
          </a>
        </div>
      </div>
    </section>

    
</Layout>
