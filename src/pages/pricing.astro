---
import Layout from '../layouts/Layout.astro';

const title = "Pricing — Maple Leaf ERP | FBR-Compliant Plans from PKR 2,000/month";
const description =
  "FBR digital invoicing included in every Maple Leaf ERP plan. Basic PKR 2,000/mo, Pro PKR 3,000/mo, Pro Max PKR 5,000/mo, Enterprise custom. IRN and QR code on every invoice.";
---

<Layout title={title} description={description} active="pricing">
    <!-- Hero Section -->
    <section
      class="bg-gradient-to-br from-primary-50 via-red-50 to-orange-50 pt-28 pb-16"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1
          class="text-3xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-4 md:mb-6"
        >
          Straightforward plans
        </h1>
        <p class="text-base md:text-xl text-gray-600 max-w-2xl mx-auto">
          Honest pricing. Designed for your success. FBR digital invoicing
          included in every plan.
        </p>
      </div>
    </section>

    <!-- Pricing Cards Section -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 max-w-7xl mx-auto"
        >
          <!-- Basic Plan -->
          <div class="bg-white border-2 border-gray-200 p-5 md:p-7 rounded-xl md:rounded-2xl hover-lift flex flex-col">
            <div class="mb-4 md:mb-6">
              <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-2">Basic</h3>
              <div class="flex items-baseline mb-3">
                <span class="text-3xl md:text-4xl font-bold text-gray-900">PKR 2,000</span><span class="text-sm text-gray-600 ml-2">/month</span>
              </div>
              <p class="text-xs md:text-sm text-gray-600">For small businesses getting started.</p>
            </div>
            <ul class="space-y-3 mb-6 md:mb-8 flex-1">
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Up to 50 invoices per month</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">FBR Digital Invoicing (PRAL connected)</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">IRN + QR code on every invoice</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Cloud based</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Standard support</span></li>
            </ul>
            <a href="/contact/?message=I'm interested in the Basic plan." class="w-full border-2 border-primary-600 text-primary-600 py-2.5 md:py-3 rounded-lg text-sm md:text-base font-semibold hover:bg-primary-50 transition block text-center">Choose Plan</a>
          </div>
          <!-- Pro Plan -->
          <div class="bg-primary-600 text-white p-5 md:p-7 rounded-xl md:rounded-2xl hover-lift relative flex flex-col">
            <div class="absolute top-0 right-0 bg-gray-900 text-white px-3 py-1 rounded-bl-lg rounded-tr-xl md:rounded-tr-2xl text-xs font-bold">Popular</div>
            <div class="mb-4 md:mb-6 mt-6 md:mt-0">
              <h3 class="text-lg md:text-xl font-bold mb-2">Pro</h3>
              <div class="flex items-baseline mb-3">
                <span class="text-3xl md:text-4xl font-bold">PKR 3,000</span><span class="text-sm text-primary-100 ml-2">/month</span>
              </div>
              <p class="text-xs md:text-sm text-primary-100">For growing businesses that need more.</p>
            </div>
            <ul class="space-y-3 mb-6 md:mb-8 flex-1">
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm">Up to 100 invoices per month</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm">Everything in Basic</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm">Sales tax return data export (FBR format)</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm">FBR error-code alerts</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm">Priority support</span></li>
            </ul>
            <a href="/contact/?message=I'm interested in the Pro plan." class="w-full bg-gray-900 text-white py-2.5 md:py-3 rounded-lg text-sm md:text-base font-semibold hover:bg-gray-800 transition block text-center">Choose Plan</a>
          </div>
          <!-- Pro Max Plan -->
          <div class="bg-white border-2 border-gray-200 p-5 md:p-7 rounded-xl md:rounded-2xl hover-lift flex flex-col">
            <div class="mb-4 md:mb-6">
              <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-2">Pro Max</h3>
              <div class="flex items-baseline mb-3">
                <span class="text-3xl md:text-4xl font-bold text-gray-900">PKR 5,000</span><span class="text-sm text-gray-600 ml-2">/month</span>
              </div>
              <p class="text-xs md:text-sm text-gray-600">For high-volume businesses.</p>
            </div>
            <ul class="space-y-3 mb-6 md:mb-8 flex-1">
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Up to 200 invoices per month</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Everything in Pro</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Multi-branch FBR reporting</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Advanced analytics dashboard</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Priority FBR support</span></li>
            </ul>
            <a href="/contact/?message=I'm interested in the Pro Max plan." class="w-full border-2 border-primary-600 text-primary-600 py-2.5 md:py-3 rounded-lg text-sm md:text-base font-semibold hover:bg-primary-50 transition block text-center">Choose Plan</a>
          </div>
          <!-- Enterprise Plan -->
          <div class="bg-white border-2 border-gray-200 p-5 md:p-7 rounded-xl md:rounded-2xl hover-lift flex flex-col">
            <div class="mb-4 md:mb-6">
              <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-2">Enterprise</h3>
              <div class="flex items-baseline mb-3">
                <span class="text-2xl md:text-3xl font-bold text-gray-900">Custom Pricing</span>
              </div>
              <p class="text-xs md:text-sm text-gray-600">For large businesses with custom needs.</p>
            </div>
            <ul class="space-y-3 mb-6 md:mb-8 flex-1">
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Unlimited invoices</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Everything in Pro Max</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Custom JSON schema mapping</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">FBR scenario sandbox testing</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">Dedicated setup & onboarding</span></li>
              <li class="flex items-center gap-2 md:gap-3"><svg class="w-4 h-4 md:w-5 md:h-5 text-primary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-xs md:text-sm text-gray-600">24/7 premium support</span></li>
            </ul>
            <a href="/contact/?message=I'm interested in the Enterprise plan. Please contact me." class="w-full border-2 border-primary-600 text-primary-600 py-2.5 md:py-3 rounded-lg text-sm md:text-base font-semibold hover:bg-primary-50 transition block text-center">Contact Sales</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faqs" class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Frequently Asked Questions
          </h2>
          <p class="text-base md:text-lg text-gray-600">
            Everything you need to know about our pricing
          </p>
        </div>

        <div class="space-y-4">
          <!-- FAQ Item — FBR 1 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                Does Maple Leaf ERP handle FBR digital invoicing?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                Yes. Every invoice is automatically submitted to FBR's Digital Invoicing system in real time. You receive an IRN and QR code on every invoice — fully compliant with S.R.O. 709(I)/2025 and Rule 150Q of the Sales Tax Rules 2006.
              </p>
            </div>
          </div>

          <!-- FAQ Item — FBR 2 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                Which plan includes FBR digital invoicing?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                All plans include FBR integration. Basic covers up to 50 invoices/month. Pro covers 100. Pro Max covers 200. Enterprise is unlimited. IRN and QR code generation is included in every plan.
              </p>
            </div>
          </div>

          <!-- FAQ Item 1 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                Can I switch plans later?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                Yes — upgrade or downgrade any time from your dashboard. Changes take effect on your next billing date with no data loss.
              </p>
            </div>
          </div>

          <!-- FAQ Item 2 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                Is there a free trial available?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                We offer a live demo with a full FBR integration walkthrough. Book via the Contact page — our team will walk you through the platform before you commit.
              </p>
            </div>
          </div>

          <!-- FAQ Item 3 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                What payment methods do you accept?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                We accept bank transfers and major debit/credit cards. Enterprise customers can arrange invoiced billing.
              </p>
            </div>
          </div>

          <!-- FAQ Item 4 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                Can I cancel my subscription anytime?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                Yes. Cancel before your next billing date and you will not be charged again. Your data is accessible for 30 days after cancellation.
              </p>
            </div>
          </div>

          <!-- FAQ Item 5 -->
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <button
              class="faq-toggle w-full flex items-center justify-between text-left"
             
            >
              <h3 class="text-lg font-semibold text-gray-900 pr-4">
                Do you offer discounts for annual billing?
              </h3>
              <svg
                class="faq-icon w-6 h-6 text-gray-400 flex-shrink-0 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div class="faq-content hidden mt-3">
              <p class="text-gray-600">
                Yes — annual plans save you two months compared to monthly billing. Contact our team for a quote.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Still have questions?
        </h2>
        <p class="text-base md:text-lg text-gray-600 mb-8">
          Our team is here to help you find the perfect plan for your business
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact/"
            class="bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-primary-700 transition"
          >
            Contact Sales
          </a>
          <a
            href="/contact/?message=I would like to schedule a demo of Maple Leaf ERP."
            class="border-2 border-primary-600 text-primary-600 px-8 py-3 rounded-lg font-semibold text-base hover:bg-primary-50 transition"
          >
            Schedule Demo
          </a>
        </div>
      </div>
    </section>

    
<script>
  document.querySelectorAll(".faq-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector(".faq-icon");
      content?.classList.toggle("hidden");
      icon?.classList.toggle("rotate-180");
    });
  });
</script>
</Layout>
