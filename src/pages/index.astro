    </section>

    <!-- Know Your Buyer Section -->
    <section class="py-12 md:py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-6 md:gap-16 items-center">
          <!-- Left - Content -->
          <div>
            <h2
              class="text-2xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-3 md:mb-6 leading-tight"
            >
              Smart Business Starts with Knowing Your Buyer.
            </h2>
            <p
              class="text-sm md:text-lg text-gray-600 mb-6 md:mb-8 leading-relaxed"
