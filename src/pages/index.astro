      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8 md:mb-16">
          <h2
            class="text-2xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-3 md:mb-4 px-4"
          >
            Meet your business’s new best friend: Maple Leaf ERP!
          </h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-6 md:gap-16 items-center">
          <!-- Left - Checklist -->
          <div class="space-y-4 md:space-y-6">
            <div class="flex items-start gap-3 md:gap-4">
              <div
                class="w-5 h-5 md:w-6 md:h-6 rounded-full bg-gray-300 flex items-center justify-center flex-shrink-0 mt-0.5 md:mt-1"
              >
                <svg
                  class="w-4 h-4 text-gray-700"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </div>
              <div>
                <h3
                  class="text-lg md:text-xl font-bold text-gray-900 mb-1 md:mb-2"
                >
                  Works as CRM
                </h3>
                <p class="text-sm md:text-base text-gray-600">
                  Effortlessly manage customer relationships and track every
                  interaction in one seamless system.
                  <br />
