---
import Layout from '../layouts/Layout.astro';

const title = "Maple Leaf ERP | FBR Digital Invoicing & IRIS Integration Pakistan";
const description =
  "FBR-compliant ERP software for Pakistani businesses. Maple Leaf ERP submits invoices to FBR's Digital Invoicing system in real time, generating IRN and QR codes automatically. Plans from PKR 2,000/month.";
const ogTitle = "Maple Leaf ERP | FBR Digital Invoicing for Pakistani Businesses";
const ogDescription =
  "Stay FBR-compliant from day one. Real-time invoice submission to FBR, automatic IRN & QR codes, CRM, sales and inventory — all in one dashboard.";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Maple Leaf ERP",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description:
    "Cloud ERP for Pakistani businesses with built-in FBR digital invoicing, CRM, sales management, inventory, and analytics.",
  offers: { "@type": "Offer", price: "2000", priceCurrency: "PKR" },
  featureList: [
    "FBR digital invoicing",
    "Real-time IRN generation",
    "FBR QR code on invoices",
    "Sales and purchase invoicing",
    "CRM",
    "Inventory management",
    "Sales analytics",
  ],
  areaServed: { "@type": "Country", name: "Pakistan" },
  url: "https://mapleleafcorporation.com",
};
---

<Layout title={title} description={description} ogTitle={ogTitle} ogDescription={ogDescription} jsonLd={jsonLd}>
    <!-- Hero Section -->
    <section
      class="bg-gradient-to-br from-gray-50 to-gray-100 pt-20 pb-12 md:pt-28 md:pb-16 md:min-h-screen flex items-center"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="text-center mb-6 md:mb-12">
          <h1
            class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-3 md:mb-6 leading-tight max-w-4xl mx-auto px-2"
          >
            Accelerate business growth through smart ERP solutions with Maple
            Leaf ERP.
          </h1>
          <p
            class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-600 mb-4 md:mb-8 leading-relaxed max-w-2xl mx-auto px-2"
          >
            Stay FBR-compliant from day one. Maple Leaf ERP submits your invoices
            to FBR's Digital Invoicing system in real time — generating IRN and
            QR codes automatically — all from one dashboard built for Pakistani
            businesses.
          </p>

          <!-- CTA -->
          <div
            class="flex flex-col sm:flex-row gap-2 sm:gap-3 justify-center items-center max-w-xl mx-auto mb-8 md:mb-12 px-2"
          >
            <a
              href="/contact/"
              class="w-full sm:w-auto bg-primary-600 text-white px-6 sm:px-8 py-3 sm:py-3.5 rounded-lg font-medium text-sm sm:text-base hover:bg-primary-700 transition whitespace-nowrap"
            >
              Contact Now
            </a>
          </div>
        </div>

        <!-- Dashboard Preview -->
        <div class="relative max-w-5xl mx-auto px-2">
          <div
            class="relative rounded-xl md:rounded-2xl overflow-hidden shadow-2xl"
          >
            <div
              class="bg-white rounded-t-xl md:rounded-t-2xl p-2 md:p-3 border-b border-gray-200"
            >
              <div class="flex items-center gap-2">
                <div class="flex gap-1 md:gap-1.5">
                  <div
                    class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-red-400"
                  ></div>
                  <div
                    class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-yellow-400"
                  ></div>
                  <div
                    class="w-2 h-2 md:w-3 md:h-3 rounded-full bg-green-400"
                  ></div>
                </div>
              </div>
            </div>
            <div class="bg-white">
              <img
                src="/assets/dashboard.jpg"
                alt="Dashboard Preview"
                class="w-full h-auto shadow-lg object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FBR Compliance Banner -->
    <div class="bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="bg-primary-50 border-l-4 border-primary-600 rounded-r-lg px-4 py-3 md:px-6 md:py-4 mt-10 md:mt-16 relative z-10 shadow-sm flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4"
        >
          <p class="text-xs md:text-sm text-gray-700 leading-relaxed flex-1">
            <strong class="font-semibold text-gray-900">FBR Digital Invoicing is now mandatory under S.R.O. 709(I)/2025.</strong>
            Sales-tax-registered businesses must submit invoices electronically
            to FBR in real time — or face penalties. Maple Leaf ERP makes this seamless.
          </p>
          <a
            href="/fbr-integration/"
            class="text-xs md:text-sm font-semibold text-primary-600 underline whitespace-nowrap hover:text-primary-700"
            >See how it works →</a
          >
        </div>
      </div>
    </div>

    <!-- Features Section -->
    <section class="py-12 md:py-20 bg-white" id="features">
