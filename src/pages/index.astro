              <img
                loading="lazy" src="/assets/total-sale.jpg"
                alt="Sales Report"
                class="w-full h-auto rounded-md md:rounded-lg object-cover"
              />
            </div>

            <!-- Center Card -->
            <div
              class="bg-white rounded-lg md:rounded-xl shadow-2xl  transform hover:scale-105 transition-transform w-40 md:w-56 z-20"
            >
              <img
