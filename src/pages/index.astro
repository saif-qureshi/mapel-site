              >
                <svg
                  class="w-4 h-4 text-gray-700"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </div>
              <div>
                <h3
                  class="text-lg md:text-xl font-bold text-gray-900 mb-1 md:mb-2"
                >
                  One System for Sales, Stock &amp; Tax
                </h3>
                <p class="text-sm md:text-base text-gray-600">
                  Your sales, inventory, and FBR reporting live in one place — no
                  spreadsheet juggling and no reconciliation headaches.
                </p>
              </div>
            </div>

            <div class="flex items-start gap-3 md:gap-4">
              <div
                class="w-5 h-5 md:w-6 md:h-6 rounded-full bg-gray-300 flex items-center justify-center flex-shrink-0 mt-0.5 md:mt-1"
              >
                <svg
                  class="w-4 h-4 text-gray-700"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </div>
