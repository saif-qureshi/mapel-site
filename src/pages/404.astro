---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Maple Leaf ERP"
  description="The page you're looking for doesn't exist or has moved."
  noindex={true}
>
  <section
    class="min-h-[70vh] flex items-center bg-gradient-to-br from-primary-50 via-red-50 to-orange-50 pt-28 pb-16"
  >
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-6xl md:text-8xl font-bold text-primary-600">404</p>
      <h1 class="text-2xl md:text-4xl font-bold text-gray-900 mt-4 mb-3">Page not found</h1>
      <p class="text-sm md:text-lg text-gray-600 mb-8">
        Sorry, the page you're looking for doesn't exist or has moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="bg-primary-600 text-white px-6 py-3 rounded-lg font-semibold text-sm md:text-base hover:bg-primary-700 transition"
        >
          Back to home
        </a>
        <a
          href="/contact/"
          class="border-2 border-primary-600 text-primary-600 px-6 py-3 rounded-lg font-semibold text-sm md:text-base hover:bg-primary-50 transition"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>
</Layout>
