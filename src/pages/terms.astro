---
import Layout from '../layouts/Layout.astro';

const title = "Terms & Conditions | Maple Leaf Corporation";
const description =
  "The terms and conditions governing use of the Maple Leaf Corporation website and services.";
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 via-red-50 to-orange-50 pt-28 pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-3 md:mb-4">Terms &amp; Conditions</h1>
      <p class="text-sm md:text-base text-gray-500">Last updated: June 2026</p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-sm md:text-base text-gray-600 leading-relaxed">
      <p>
        Welcome to Maple Leaf Corporation. By accessing or using this website, you agree to
        comply with and be bound by the following Terms &amp; Conditions. If you do not agree
        with these terms, please refrain from using the website.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">About Maple Leaf Corporation</h2>
      <p>
        Maple Leaf Corporation is a technology solutions provider specializing in ERP software,
        business management systems, process automation, and digital transformation services
        for organizations across manufacturing, distribution, retail, wholesale, logistics,
        trading, and service industries.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Website Use</h2>
      <p class="mb-3">
        You agree to use this website only for lawful purposes and in a manner that does not
        infringe upon the rights of others or restrict their use of the website. Users must not:
      </p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Attempt unauthorized access to systems or data</li>
        <li>Distribute malicious software or harmful content</li>
        <li>Misrepresent their identity or business information</li>
        <li>Use website content for unlawful purposes</li>
      </ul>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Intellectual Property</h2>
      <p>
        All website content, including text, graphics, logos, software, designs, and other
        materials, is the property of Maple Leaf Corporation unless otherwise stated.
        Unauthorized reproduction, distribution, or modification is prohibited.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Service Information</h2>
      <p>
        Information provided on this website is for general informational purposes only. While
        we strive for accuracy, Maple Leaf Corporation does not guarantee that all content is
        complete, current, or error-free.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Third-Party Links</h2>
      <p>
        This website may contain links to third-party websites for informational purposes.
        Maple Leaf Corporation is not responsible for the content, policies, or practices of
        external websites.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Limitation of Liability</h2>
      <p>
        Maple Leaf Corporation shall not be liable for any direct, indirect, incidental,
        consequential, or special damages arising from the use of or inability to use this
        website or related services.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">User Submissions</h2>
      <p>
        Any information submitted through forms, inquiries, or communications must be accurate
        and lawful. Users remain responsible for the information they provide.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Privacy</h2>
      <p>
        Use of this website is also governed by our
        <a href="/privacy/" class="text-primary-600 hover:text-primary-700 font-medium underline">Privacy Policy</a>,
        which explains how personal information is collected and processed.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Changes to Terms</h2>
      <p>
        Maple Leaf Corporation reserves the right to modify these Terms &amp; Conditions at any
        time without prior notice. Continued use of the website constitutes acceptance of any
        revised terms.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Governing Law</h2>
      <p>
        These Terms &amp; Conditions shall be governed by and interpreted in accordance with the
        laws of Pakistan. Any disputes arising from website use shall be subject to the
        jurisdiction of the courts of Pakistan.
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mt-8 mb-3">Contact Information</h2>
      <p>
        For questions regarding these Terms &amp; Conditions, please
        <a href="/contact/" class="text-primary-600 hover:text-primary-700 font-medium underline">contact Maple Leaf Corporation</a>
        using the contact information available on our website.
      </p>
    </div>
  </section>
</Layout>
